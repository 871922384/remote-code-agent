{
  "name": "remote-code-agent",
  "version": "1.0.0",
  "description": "Remote wrapper for Claude Code & Codex CLI",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build": "vite build",
    "test:server": "node --test tests/*.test.js",
    "test:ui": "vitest run tests/ui",
    "test": "npm run test:server && npm run test:ui"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "vue": "^3.5.31"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.1.0",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  }
}
