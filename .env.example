# Copy to .env and fill in

# Required: access token for the web UI
AUTH_TOKEN=your-strong-secret-token-here

# Optional: default working directory for CLI commands
DEFAULT_CWD=C:\Users\YourName\projects

# Optional: port (default 3333)
PORT=3333

# Optional: override the Claude Code CLI provider used by the web service
# If unset, Claude keeps using its own local settings (for example cc-switch output in ~/.claude/settings*.json)
# These values are injected only into the Claude child process launched by the web service
CLAUDE_ANTHROPIC_BASE_URL=
CLAUDE_ANTHROPIC_AUTH_TOKEN=
CLAUDE_ANTHROPIC_API_KEY=
